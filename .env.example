# ==============================================================================
# MCP TRON Server - Environment Variables Example
# ==============================================================================

# ------------------------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------------------------

# The port the HTTP server will listen on (default: 3001)
# MCP_PORT=3001

# The host the HTTP server will bind to (default: 0.0.0.0)
# MCP_HOST=0.0.0.0

# Public origin used for OAuth issuer, authorization endpoint, token endpoint, and MCP resource URI
# MCP_PUBLIC_ORIGIN=https://tron-mcp.example.com

# JWT secret used to sign OAuth access tokens
# JWT_SECRET=change-me

# Master secret used to derive deterministic per-tenant wallet passwords
# MCP_TENANT_MASTER_SECRET=change-me-too

# Data directory for tenant wallet and OAuth refresh-token storage (default: ./data)
# MCP_DATA_DIR=./data

# Optional OAuth/browser-auth TTLs
# MCP_AUTH_CHALLENGE_TTL_SECONDS=300
# MCP_OAUTH_AUTH_CODE_TTL_SECONDS=300
# MCP_OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600
# MCP_OAUTH_REFRESH_TOKEN_TTL_SECONDS=2592000

# Log directory path (default: ./logs)
# MCP_LOG_DIR=./logs

# Node environment (default: production)
# NODE_ENV=production

# ------------------------------------------------------------------------------
# Blockchain Configuration
# ------------------------------------------------------------------------------

# Optional: TronGrid API Key to avoid rate limits on Mainnet
# Get one at https://www.trongrid.io/
# TRONGRID_API_KEY=your_trongrid_api_key_here

# Optional explicit RPC endpoint overrides
# TRON_MAINNET_FULL_NODE=https://api.trongrid.io
# TRON_MAINNET_SOLIDITY_NODE=https://api.trongrid.io
# TRON_MAINNET_EVENT_SERVER=https://api.trongrid.io
# TRON_NILE_FULL_NODE=https://nile.trongrid.io
# TRON_NILE_SOLIDITY_NODE=https://nile.trongrid.io
# TRON_NILE_EVENT_SERVER=https://nile.trongrid.io
# TRON_SHASTA_FULL_NODE=https://api.shasta.trongrid.io
# TRON_SHASTA_SOLIDITY_NODE=https://api.shasta.trongrid.io
# TRON_SHASTA_EVENT_SERVER=https://api.shasta.trongrid.io

# ------------------------------------------------------------------------------
# Wallet Configuration
# ------------------------------------------------------------------------------

# Wallets are managed through agent-wallet file-backed configuration. Please see the agent-wallet docs.
