{
  "name": "@missionsquad/mcp-server-tron",
  "mcpName": "io.github.missionsquad/mcp-server-tron",
  "module": "build/index.js",
  "type": "module",
  "version": "1.2.0",
  "description": "MCP server for TRON blockchain. Supports TRX/TRC20 transfers, smart contracts, AI prompts & OAuth 2.0",
  "bin": {
    "mcp-server-tron": "./bin/cli.js"
  },
  "main": "build/index.js",
  "files": [
    "build/",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start:http": "tsx src/server/http-server.ts",
    "dev:http": "tsx watch src/server/http-server.ts",
    "test": "vitest run",
    "test:ci": "vitest run --exclude tests/core/services/account-data.test.ts --exclude tests/core/services/account.test.ts --exclude tests/core/services/estimation.test.ts --exclude tests/core/services/events.test.ts --exclude tests/core/services/governance.test.ts --exclude tests/core/services/mempool.test.ts --exclude tests/core/services/multicall.test.ts --exclude tests/core/services/nodes.test.ts --exclude tests/core/services/proposals.test.ts --exclude tests/core/services/services.test.ts --exclude tests/core/tools/account-data-e2e.test.ts --exclude tests/core/tools_integration.test.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "npm run build",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "release": "npm publish",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0",
    "changelog:latest": "conventional-changelog -p angular -r 1 > RELEASE_NOTES.md",
    "inspect": "npx @modelcontextprotocol/inspector npx tsx src/index.ts"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^22.19.7",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "conventional-changelog-cli": "^5.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.1.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1",
    "vitest": "^4.0.17"
  },
  "peerDependencies": {
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@missionsquad/agent-wallet": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.22.0",
    "@scure/bip32": "^2.0.1",
    "@scure/bip39": "^2.0.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "tronweb": "^6.1.1",
    "zod": "^3.24.3"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "tron",
    "blockchain",
    "trx",
    "smart-contracts",
    "ai",
    "agent",
    "trc20",
    "trc721"
  ],
  "author": "Mission Squad AI <jayson@missionsquad.ai>",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MissionSquad/mcp-server-tron"
  },
  "bugs": {
    "url": "https://github.com/MissionSquad/mcp-server-tron/issues"
  },
  "homepage": "https://github.com/MissionSquad/mcp-server-tron#readme",
  "publishConfig": {
    "access": "public"
  }
}
